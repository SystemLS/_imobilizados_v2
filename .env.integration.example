# API INTEGRATION CONFIGURATION

# ============================================================================
# SANCTUM - AUTENTICAÇÃO DE API
# ============================================================================

# Domínios que podem fazer requisições com autenticação stateful
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:5173,127.0.0.1:8000

# Tempo de expiração do token em minutos (null = sem expiração)
# Para segurança, recomenda-se definir um tempo
SANCTUM_EXPIRATION=43200  # 30 dias

# ============================================================================
# CORS - COMPARTILHAMENTO DE RECURSOS ENTRE ORIGENS
# ============================================================================

# Origens permitidas para requisições CORS
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173,https://seu-frontend.com

# Padrão regex para origens dinâmicas (opcional)
CORS_ALLOWED_PATTERNS=^https?://.*\.seu-dominio\.com$

# ============================================================================
# QUEUE - FILAS PARA PROCESSAMENTO ASSÍNCRONO
# ============================================================================

# Driver de fila (sync, database, redis, beanstalkd, sqs)
QUEUE_CONNECTION=database  # Usar 'redis' ou 'beanstalkd' em produção

# Redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Beanstalkd
BEANSTALKD_HOST=127.0.0.1
BEANSTALKD_QUEUE=default

# ============================================================================
# WEBHOOK - NOTIFICAÇÕES PARA SISTEMAS EXTERNOS
# ============================================================================

# Timeout para requisições de webhook (segundos)
WEBHOOK_TIMEOUT=30

# Máximo de tentativas de envio de webhook
WEBHOOK_MAX_RETRIES=5

# ============================================================================
# API - DOCUMENTAÇÃO E RATE LIMITING
# ============================================================================

# URL base da API (usado em documentação)
API_URL=http://localhost:8000

# Rate limiting (requests por minuto)
RATE_LIMIT=60

# ============================================================================
# MONITORING
# ============================================================================

# Ativar logs detalhados de API
API_LOGGING=true

# Logs de webhook (debug, webhook)
WEBHOOK_LOG_CHANNEL=webhook
